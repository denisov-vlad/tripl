# ── Backend ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tripl:tripl@localhost:5432/tripl
SYNC_DATABASE_URL=postgresql+psycopg://tripl:tripl@localhost:5432/tripl
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
REDIS_URL=

API_PORT=8000
DEBUG=true
APP_BASE_URL=http://localhost:5173

# Session cookies. SECURE must be true for any HTTPS deployment.
SESSION_COOKIE_NAME=tripl_session
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false

# Fernet key for encrypting data-source and alert-destination secrets at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production; empty is tolerated only when DEBUG=true.
ENCRYPTION_KEY=

# CORS allow-list (comma-separated). When empty:
#   - DEBUG=true  → "*" (no credentials)
#   - DEBUG=false → derived from APP_BASE_URL, or denied if both empty
CORS_ALLOW_ORIGINS=

# Security headers. HSTS should be off until you serve over HTTPS exclusively.
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000
# Optional Content-Security-Policy. Leave empty to omit the header until you've
# reviewed a policy for your origin (e.g. "default-src 'self'").
CONTENT_SECURITY_POLICY=

# Rate limiting for auth endpoints. 0 disables an individual limit.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_REGISTER_PER_HOUR=3

# Logging. LOG_JSON=true emits one-line JSON suited for container log shippers.
LOG_LEVEL=INFO
LOG_JSON=false
REQUEST_ID_HEADER=X-Request-ID

# ── PostgreSQL (Docker Compose) ────────────────────────────────────────────
POSTGRES_USER=tripl
POSTGRES_PASSWORD=tripl
POSTGRES_DB=tripl

# ── Frontend ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
